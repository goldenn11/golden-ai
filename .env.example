# =============================================================================
# ClawPort — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# See SETUP.md for detailed instructions on finding each value.
# =============================================================================

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Path to your OpenClaw workspace directory.
# Default location: ~/.openclaw/workspace
# Find yours: ls ~/.openclaw/workspace
WORKSPACE_PATH=/Users/yourname/.openclaw/workspace

# Anthropic API key for direct Claude API access.
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# ElevenLabs API key — enables text-to-speech for voice messages.
# Get one at: https://elevenlabs.io
# ELEVENLABS_API_KEY=sk_your-elevenlabs-key-here

# OpenAI API key — enables Whisper audio transcription for voice input.
# Get one at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# ---------------------------------------------------------------------------
# Notion Integration
# ---------------------------------------------------------------------------

# Notion API key — enables Call Reviews and Cron Run logging.
# Create an integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your-notion-key-here

# Notion Call Reviews database ID.
# NOTION_CALL_REVIEWS_DB_ID=your-database-id-here

# Notion Cron Runs database ID — stores cron execution history.
# Create a database with properties: Job ID (title), Job Name (rich_text),
# Status (select: ok/error/idle), Duration Ms (number), Summary (rich_text),
# Error (rich_text), Ran At (date).
# NOTION_CRON_RUNS_DB_ID=your-database-id-here

# ---------------------------------------------------------------------------
# Vercel Cron
# ---------------------------------------------------------------------------

# Secret token for authenticating Vercel cron job invocations.
# Set this in Vercel env vars — cron routes check Authorization header.
# CRON_SECRET=your-cron-secret-here
